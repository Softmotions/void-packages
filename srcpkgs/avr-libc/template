# Template file for 'avr-libc'
pkgname=avr-libc
version=2.3.1
revision=1
short_desc="C library for use with GCC on Atmel AVR microcontrollers"
maintainer="Orphaned <orphan@voidlinux.org>"
license="BSD-3-Clause"
homepage="http://savannah.nongnu.org/projects/avr-libc/"
distfiles="https://github.com/avrdudes/avr-libc/releases/download/avr-libc-2_3_1-release/avr-libc-2.3.1.tar.bz2"
checksum=2ec0827ec833ca6715a87221f31799d60da1c8638aa98eaafae42e0c2e302f5c

build_style=gnu-configure
hostmakedepends="avr-binutils avr-gcc"
depends="avr-binutils avr-gcc"
nostrip=yes

do_configure() {
	CC=avr-gcc AR=avr-ar AS=avr-as LD=avr-ld OBJDUMP=avr-objdump RANLIB=avr-ranlib \
	./configure --build=${XBPS_TRIPLET} --host=avr --prefix=/usr
}
post_install() {
	rm ${DESTDIR}/usr/bin/avr-man
	vlicense LICENSE
}
